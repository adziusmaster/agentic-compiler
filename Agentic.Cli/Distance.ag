version: 0.5
name: PointDistanceEngine

objective: |
  Read four input arguments Ax, Ay, Bx, By (any real numbers).
  Declare (defstruct Point (x y)) at the root of the program.
  Construct two points a and b via (Point.new …).
  Compute the Euclidean distance:
    dx = (- (Point.x b) (Point.x a))
    dy = (- (Point.y b) (Point.y a))
    result = (math.sqrt (+ (* dx dx) (* dy dy)))
  Output the distance and nothing else.

permissions:
  - sys.stdout.write
  - sys.input.get
  - defstruct
  - math.sqrt

tests:
  - input: [0, 0, 3, 4]
    expect_stdout: "5"
  - input: [1, 1, 4, 5]
    expect_stdout: "5"
  - input: [0, 0, 0, 0]
    expect_stdout: "0"
