version: 0.5
name: SquareSum

objective: |
  Read two input arguments a and b.
  Print the result of (square a) + (square b).
  Example: a=3, b=4 → 25

permissions:
  - sys.stdout.write
  - sys.input.get

functions:
  - name: square
    signature: (square n)
    intent: "Return n * n"
    tests:
      - inputs: [3]
        expect: "9"
      - inputs: [5]
        expect: "25"
      - inputs: [0]
        expect: "0"

tests:
  - input: [3, 4]
    expect_stdout: "25"
  - input: [5, 12]
    expect_stdout: "169"
  - input: [0, 0]
    expect_stdout: "0"
