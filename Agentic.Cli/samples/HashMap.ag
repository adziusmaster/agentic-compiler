(module HashMap
  ;; Demonstrates HashMap (dictionary) operations

  (test basic_map_operations
    (do
      (def scores : (Map Str Num) (map.new))
      (map.set scores "alice" 95)
      (map.set scores "bob" 87)
      (map.set scores "charlie" 92)
      (assert-eq (map.get scores "alice") 95)
      (assert-eq (map.get scores "bob") 87)
      (assert-eq (map.has scores "alice") 1)
      (assert-eq (map.size scores) 3)))

  (test map_update
    (do
      (def m : (Map Str Num) (map.new))
      (map.set m "x" 10)
      (map.set m "x" 20)
      (assert-eq (map.get m "x") 20)
      (assert-eq (map.size m) 1)))

  (test map_remove
    (do
      (def m : (Map Str Num) (map.new))
      (map.set m "a" 1)
      (map.set m "b" 2)
      (map.remove m "a")
      (assert-eq (map.has m "a") 0)
      (assert-eq (map.size m) 1)))

  ;; Build a frequency map from 5 CLI args (as numbers)
  ;; Usage: HashMap 10 20 10 30 10
  (def freq : (Map Str Num) (map.new))
  (def i : Num 0)
  (while (< i 5)
    (do
      (def key : Str (sys.input.get_str i))
      (if (map.has freq key)
        (map.set freq key (+ (map.get freq key) 1))
        (map.set freq key 1))
      (set i (+ i 1))))
  (def keys : (Array Str) (map.keys freq))
  (def k : Num 0)
  (while (< k (arr.length keys))
    (do
      (def key : Str (arr.get keys k))
      (if (> k 0) (sys.stdout.write ",") 0)
      (sys.stdout.write (str.concat key (str.concat "=" (str.from_num (map.get freq key)))))
      (set k (+ k 1)))))
