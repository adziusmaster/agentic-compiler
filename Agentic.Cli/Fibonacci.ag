version: 0.1
name: FibonacciEngine

objective: |
  Read the first input argument N.
  Calculate the Nth Fibonacci number.
  Assume Fib(0) = 0 and Fib(1) = 1.
  Output the exact result and nothing else.

permissions:
  - sys.stdout.write
  - sys.input.get

tests:
  - input: [0]
    expect_stdout: "0"
  - input: [5]
    expect_stdout: "5"
  - input: [7]
    expect_stdout: "13"
  - input: [10]
    expect_stdout: "55"