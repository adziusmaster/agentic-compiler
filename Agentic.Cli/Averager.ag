version: 0.3
name: AverageEngine

objective: |
  Read exactly 3 input arguments from the OS.
  1. Allocate an array of size 3.
  2. Use a while loop to fill the array with (sys.input.get index). 
     Note: Inputs are 0-indexed (indices 0, 1, and 2).
  3. Use a second while loop to calculate the sum of the array elements.
  4. Divide the sum by 3.0 and output the result.

permissions:
  - sys.stdout.write
  - sys.input.get
  - arr.new
  - arr.get
  - arr.set

tests:
  - input: [10, 20, 30]
    expect_stdout: "20"
  - input: [5, 10, 15]
    expect_stdout: "10"