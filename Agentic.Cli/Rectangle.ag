version: 0.5
name: RectangleAreaEngine

objective: |
  Read two input arguments W and H (positive numbers).
  Declare a (defstruct Rect (w h)) at the root of the program.
  Construct a Rect via (Rect.new …) using the two inputs.
  Output the area as (* width height) using the field accessors (Rect.w r) and (Rect.h r).
  Nothing else.

permissions:
  - sys.stdout.write
  - sys.input.get
  - defstruct

tests:
  - input: [10, 5]
    expect_stdout: "50"
  - input: [7, 3]
    expect_stdout: "21"
  - input: [1, 1]
    expect_stdout: "1"
