version: 0.4
name: FactorialEngine

objective: |
  Read the first input argument N (a non-negative integer).
  Compute N! using a recursive defun. Base case: 0! = 1 and 1! = 1.
  The recursive case MUST call the function itself on (- N 1).
  Output the result and nothing else.

permissions:
  - sys.stdout.write
  - sys.input.get

tests:
  - input: [0]
    expect_stdout: "1"
  - input: [1]
    expect_stdout: "1"
  - input: [5]
    expect_stdout: "120"
  - input: [8]
    expect_stdout: "40320"
