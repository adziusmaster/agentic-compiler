(test annual        (assert-near (compound 1000 5 1 10) 1628.89 0.05))
(test monthly       (assert-near (compound 1000 10 12 5) 1645.31 0.05))
(test zero_rate     (assert-near (compound 5000 0 4 10) 5000 0.01))
(test double        (assert-near (compound 100 100 1 1) 200 0.01))
(test semiannual    (assert-near (compound 2000 6 2 3) 2388.10 0.05))
