(module IsPrime
  (defun is_prime ((n : Num)) : Num
    (if (< n 2) (return 0) 0)
    (if (< n 4) (return 1) 0)
    (if (= (math.mod n 2) 0) (return 0) 0)
    (def i : Num 3)
    (while (<= (* i i) n)
      (do
        (if (= (math.mod n i) 0) (return 0) 0)
        (set i (+ i 2))))
    (return 1))

  (test zero    (assert-eq (is_prime 0) 0))
  (test one     (assert-eq (is_prime 1) 0))
  (test two     (assert-eq (is_prime 2) 1))
  (test three   (assert-eq (is_prime 3) 1))
  (test four    (assert-eq (is_prime 4) 0))
  (test seven   (assert-eq (is_prime 7) 1))
  (test nine    (assert-eq (is_prime 9) 0))
  (test eleven  (assert-eq (is_prime 11) 1))
  (test fifteen (assert-eq (is_prime 15) 0))
  (test p29     (assert-eq (is_prime 29) 1)))
