(module CountChar
  (defun count_char ((s : Str) (ch : Str)) : Num
    (def n : Num (str.length s))
    (def i : Num 0)
    (def total : Num 0)
    (while (< i n)
      (do
        (if (str.eq (str.substring s i 1) ch) (set total (+ total 1)) 0)
        (set i (+ i 1))))
    (return total))

  (test empty     (assert-eq (count_char "" "a") 0))
  (test none      (assert-eq (count_char "banana" "z") 0))
  (test three     (assert-eq (count_char "banana" "a") 3))
  (test case      (assert-eq (count_char "Banana" "a") 3))
  (test case_none (assert-eq (count_char "Banana" "A") 0))
  (test all       (assert-eq (count_char "aaaa" "a") 4))
  (test spaces    (assert-eq (count_char "a b c d" " ") 3)))
