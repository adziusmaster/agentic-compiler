(module TaxProgressive
  (defun min2 ((a : Num) (b : Num)) : Num
    (if (< a b) (return a) 0)
    (return b))

  (defun max2 ((a : Num) (b : Num)) : Num
    (if (> a b) (return a) 0)
    (return b))

  (defun bracket1 ((income : Num)) : Num
    (return (* (min2 income 10000) 0.10)))

  (defun bracket2 ((income : Num)) : Num
    (def capped : Num (min2 income 50000))
    (return (* (max2 0 (- capped 10000)) 0.20)))

  (defun bracket3 ((income : Num)) : Num
    (return (* (max2 0 (- income 50000)) 0.30)))

  (defun round2 ((x : Num)) : Num
    (return (/ (math.floor (+ (* x 100) 0.5)) 100)))

  (defun income_tax ((income : Num)) : Num
    (def a : Num (bracket1 income))
    (def b : Num (bracket2 income))
    (def c : Num (bracket3 income))
    (return (round2 (+ a (+ b c)))))

  (test zero         (assert-near (income_tax 0) 0 0.01))
  (test low          (assert-near (income_tax 5000) 500 0.01))
  (test boundary1    (assert-near (income_tax 10000) 1000 0.01))
  (test mid          (assert-near (income_tax 30000) 5000 0.01))
  (test boundary2    (assert-near (income_tax 50000) 9000 0.01))
  (test high         (assert-near (income_tax 100000) 24000 0.01)))
