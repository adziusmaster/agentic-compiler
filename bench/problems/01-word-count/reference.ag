(module WordCount
  (defun is_space ((ch : Str)) : Num
    (if (or (str.eq ch " ") (str.eq ch "	")) (return 1) (return 0)))

  (defun word_count ((text : Str)) : Num
    (def n : Num (str.length text))
    (def i : Num 0)
    (def in_word : Num 0)
    (def count : Num 0)
    (while (< i n)
      (do
        (def ch : Str (str.substring text i 1))
        (if (> (is_space ch) 0)
          (set in_word 0)
          (do
            (if (= in_word 0) (set count (+ count 1)) 0)
            (set in_word 1)))
        (set i (+ i 1))))
    (return count))

  (test empty    (assert-eq (word_count "") 0))
  (test one      (assert-eq (word_count "hello") 1))
  (test two      (assert-eq (word_count "hello world") 2))
  (test leading  (assert-eq (word_count "  hi") 1))
  (test trailing (assert-eq (word_count "hi  ") 1))
  (test collapse (assert-eq (word_count "a  b   c") 3))
  (test tabs     (assert-eq (word_count "a	b	c") 3)))
