(test empty       (assert-eq (is_balanced "") 1))
(test pair        (assert-eq (is_balanced "()") 1))
(test nested      (assert-eq (is_balanced "(())") 1))
(test siblings    (assert-eq (is_balanced "(()())") 1))
(test ignore      (assert-eq (is_balanced "(a(b)c)") 1))
(test reversed    (assert-eq (is_balanced ")(") 0))
(test unclosed    (assert-eq (is_balanced "((") 0))
(test trailing    (assert-eq (is_balanced "())") 0))
(test bare_text   (assert-eq (is_balanced "abc") 1))
